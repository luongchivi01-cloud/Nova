# Runtime and generated files
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
output/
reports/
validation_run_*

# Models and datasets must not be committed
models/
models_submission/
*.gguf
*.bin
data/
knowledge/
corpus/

# Vendored research repositories are not used by the final image
third_party/

# Local secrets and tooling
.env
*.log
*.zip
*.zip.part*
cookies.txt
cookie.json
session.json
storage_state.json
.idea/
.vscode/

# Legacy/local-only project files not included in the final public package
.dockerignore
Dockerfile
Dockerfile.bak
Dockerfile.cpu-runtime
Dockerfile.selfcontained
requirements.txt
requirements-llm-transformers.txt
requirements-rag.txt
requirements-tuning.txt
requirements-vendor-research.txt
scripts/*
!scripts/validate_final_image.ps1
tests/*
!tests/test_cpu_portable.py
!tests/test_official_autorun_v6.py
